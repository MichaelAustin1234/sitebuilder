APP_NAME="UMKM Sitebuilder"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database ──────────────────────────────────────────────────────────────────
# Railway MySQL: set DB_CONNECTION=mysql and fill in values from Railway dashboard
# TiDB Serverless (free MySQL-compatible): https://tidbcloud.com
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=umkm_sitebuilder
DB_USERNAME=root
DB_PASSWORD=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=cookie
SESSION_LIFETIME=10080
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set this to your Vercel production URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# ── Cache & Queue ─────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ── Cloudinary (required for product & logo image uploads) ────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Mail (optional) ───────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@umkmsitebuilder.id"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
